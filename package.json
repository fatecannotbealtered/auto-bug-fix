{
  "name": "@fateforge/auto-bug-fix",
  "version": "1.0.16",
  "description": "Autonomous Jira DC + GitLab bug-fix scheduler — polls Jira for Bugs and dispatches each to your configured AI agent",
  "keywords": [
    "jira",
    "gitlab",
    "bug-fix",
    "ai-agent",
    "cli",
    "devtools",
    "automation",
    "jira-data-center"
  ],
  "author": "guosong6886@gmail.com",
  "homepage": "https://github.com/fatecannotbealtered/auto-bug-fix#readme",
  "bugs": {
    "url": "https://github.com/fatecannotbealtered/auto-bug-fix/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fatecannotbealtered/auto-bug-fix.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "auto-bug-fix": "scripts/run.js"
  },
  "scripts": {
    "version": "node scripts/sync-version.js",
    "check-version": "node scripts/check-version.js"
  },
  "optionalDependencies": {
    "@fateforge/auto-bug-fix-darwin-arm64": "1.0.16",
    "@fateforge/auto-bug-fix-darwin-x64": "1.0.16",
    "@fateforge/auto-bug-fix-linux-arm64": "1.0.16",
    "@fateforge/auto-bug-fix-linux-x64": "1.0.16",
    "@fateforge/auto-bug-fix-win32-arm64": "1.0.16",
    "@fateforge/auto-bug-fix-win32-x64": "1.0.16"
  },
  "files": [
    "scripts/run.js",
    "scripts/prepare-npm-platform-packages.js",
    "skills/",
    "README.md",
    "README_zh.md",
    "LICENSE",
    "NOTICE.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "AGENTS.md",
    "AGENTS_zh.md",
    ".agent/",
    "docs/"
  ],
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "engines": {
    "node": ">=16"
  }
}
